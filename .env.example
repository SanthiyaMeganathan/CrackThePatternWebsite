# Frontend environment variables
# Copy this to .env.local and fill in your values

# Backend API URL
VITE_API_URL=http://localhost:4000/api/v1

# Razorpay public key (safe to expose in frontend)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Course price in INR (for display in UI)
VITE_COURSE_PRICE_INR=4999

# Demo video embed URL
# YouTube: https://www.youtube.com/embed/YOUR_VIDEO_ID?rel=0&modestbranding=1
# Vimeo:   https://player.vimeo.com/video/YOUR_VIDEO_ID
VITE_DEMO_VIDEO_URL=https://www.youtube.com/embed/dQw4w9WgXcQ?rel=0&modestbranding=1
